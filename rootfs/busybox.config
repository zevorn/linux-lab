# Busybox minimal configuration for linux-lab prebuilt rootfs
# Used during Docker image build to cross-compile static busybox
#
# Key settings:
# - CONFIG_STATIC=y (no glibc dependency in target rootfs)
# - Core utilities enabled: sh, ls, cat, echo, mount, umount, etc.
# - Init system: init, halt, reboot
# - Network: ifconfig, route, ping (basic)
#
# To regenerate: make -C <busybox-src> ARCH=<arch> CROSS_COMPILE=<prefix> defconfig
# Then apply: sed -i 's/# CONFIG_STATIC is not set/CONFIG_STATIC=y/' .config

CONFIG_STATIC=y
CONFIG_FEATURE_INSTALLER=y
CONFIG_INSTALL_APPLET_SYMLINKS=y
CONFIG_PREFIX="/usr"
